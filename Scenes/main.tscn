horizontal_alignment = 1
vertical_alignment = 1

[node name="TickTock" type="AudioStreamPlayer" parent="."]
stream = ExtResource("20_hibaj")
volume_db = -7.5
stream_paused = true

[node name="GameTimer" type="Timer" parent="."]
wait_time = 300.0
one_shot = true
autostart = true

[node name="DifficultyTimer" type="Timer" parent="."]
wait_time = 60.0
autostart = true

[node name="DoorTimer" type="Timer" parent="."]
wait_time = 16.0

[connection signal="timeout" from="GameTimer" to="." method="_on_game_timer_timeout"]
[connection signal="timeout" from="DifficultyTimer" to="." method="_on_difficulty_timer_timeout"]
[connection signal="timeout" from="DoorTimer" to="." method="_on_door_timer_timeout"]
